# ───────────────────────────────────────────────────────────────
# Chariow Funnel Engine — variables d'environnement (SERVEUR uniquement)
# Copier vers .env.local et remplir. Ne JAMAIS exposer côté client.
# ───────────────────────────────────────────────────────────────

# Chariow — API REST (lecture seule) + signature des Pulses (webhooks)
CHARIOW_API_KEY=            # Bearer — base https://api.chariow.com/v1
CHARIOW_WEBHOOK_SECRET=     # signature des Pulses

# WasenderAPI — WhatsApp (session non officielle / QR)
WASENDER_API_KEY=           # Bearer — POST https://www.wasenderapi.com/api/send-message
WASENDER_WEBHOOK_SECRET=    # header X-Wasender-Signature

# Brevo — email transactionnel (clé API REST, != clé SMTP)
BREVO_API_KEY=              # header "api-key" — POST https://api.brevo.com/v3/smtp/email
BREVO_SENDER_EMAIL=         # expéditeur vérifié + domaine DKIM authentifié
BREVO_SENDER_NAME=

# Insforge — base de données. SERVICE_KEY = clé admin (serveur uniquement).
INSFORGE_PROJECT_URL=        # ex https://<appkey>.<region>.insforge.app
INSFORGE_API_KEY=
INSFORGE_SERVICE_KEY=        # clé admin ik_... (bypass RLS) — JAMAIS côté client

# Crons (Vercel Cron envoie "Authorization: Bearer <CRON_SECRET>")
CRON_SECRET=
